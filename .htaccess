RewriteEngine on

Options -Indexes

# Security headers (HSTS is left to Cloudflare to avoid duplicate/conflicting
# policies; add it here if you ever serve the origin directly over HTTPS).
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "no-referrer"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Advertise a Tor onion service to clearnet visitors so Tor Browser shows a
    # ".onion available" button. Deployment-specific: uncomment and set your own
    # onion address (better yet, put this on your clearnet vhost so the onion
    # stays out of a public repo). Uses ap_expr for the path (recent Apache 2.4);
    # after enabling, confirm with `curl -I` that it survives to the client, since
    # Cloudflare can strip unknown response headers. See README "Tor / onion".
    # Header always set Onion-Location "expr=http://YOURADDRESS.onion%{REQUEST_URI}"
</IfModule>

# Custom error pages.
ErrorDocument 404 /404.php
ErrorDocument 503 /503.php

# Hide sensitive files and dirs from the web. Return 404 (not 403) so their
# existence isn't even confirmed. Covers dotfiles (.git, .gitignore, .ht*, the
# balance/height caches), the database directory, and the repo metadata files.
RewriteRule (^|/)\.(?!well-known/) - [L,R=404]
RewriteRule ^(db|tools)(/|$) - [L,R=404]
RewriteRule ^(config\.php|config\.example\.php|LICENSE|README\.md|SECURITY\.md)$ - [L,R=404]

# Both Monero faucets are served by the single xmr-faucet.php, selected by ?net=.
# Internal rewrites (no R flag) so the pretty URLs stay in the address bar.
RewriteRule ^xmr-stagenet/?$ xmr-faucet.php?net=stagenet [L]
RewriteRule ^xmr-testnet/?$  xmr-faucet.php?net=testnet  [L]

# Bitcoin Core-family faucets share core-faucet.php, selected by ?coin=.
RewriteRule ^ltc-testnet/?$ core-faucet.php?coin=ltc [L]
RewriteRule ^btc-testnet/?$ core-faucet.php?coin=btc [L]

# Strip .php from direct requests only. The REDIRECT_STATUS guard keeps this
# from firing on internal error subrequests (e.g. the 404 ErrorDocument), which
# would otherwise turn a blocked /config.php into a 301 to /config.
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
RewriteRule ^ /%1 [NC,L,R]

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^ %{REQUEST_URI}.php [NC,L]
