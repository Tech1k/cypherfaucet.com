# SQLite faucet database. Contains claimer IP addresses (PII). Never commit.
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# Balance / sync-status caches written next to the DB
db/.balance_cache_*.json
db/.height_cache_*.json

# Secrets / local config
config.php

# Logs
*.log

# Python bytecode cache
__pycache__/
*.pyc

# Node status: the router (status/index.php, status/.htaccess) is committed; the
# dashboard itself (your own repo) and its per-network caches are not.
/status/dashboard.php
/status/*_cache.json
